# Environment variables template for jetstream-turbo

# Required Configuration
STREAM_NAME=hydrated_jetstream

# PostHog Configuration (optional; leave POSTHOG_API_KEY blank to disable)
POSTHOG_API_KEY=phc_your_posthog_project_key
POSTHOG_HOST=https://us.i.posthog.com

# Bluesky Authentication (Required)
# Create an app password at: https://bsky.app/settings/app-passwords
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Database Configuration
DB_DIR=data_store
REDIS_URL=redis://localhost:6379

# Database Cleanup Configuration
# 8 GB RAM / 40 GB disk profile:
# tuned for higher throughput while keeping bounded growth.
MAX_DB_SIZE_MB=20480
DB_RETENTION_DAYS=3
CLEANUP_CHECK_INTERVAL_MINUTES=5
SQLITE_CACHE_SIZE_KIB=65536
SQLITE_MMAP_SIZE_MB=256
SQLITE_JOURNAL_SIZE_LIMIT_MB=512

# Performance Configuration
TURBO_BATCH_SIZE=10
TURBO_PROFILE_BATCH_SIZE=25
TURBO_POST_BATCH_SIZE=25
TURBO_PROFILE_BATCH_WAIT_MS=150
TURBO_POST_BATCH_WAIT_MS=300
MAX_CONCURRENT_REQUESTS=6

# Cache Configuration
CACHE_SIZE_USERS=50000
CACHE_SIZE_POSTS=40000

# Stream retention
TRIM_MAXLEN=100

# Server Configuration
HTTP_PORT=8080
RUST_LOG=info

# Jetstream Configuration
JETSTREAM_HOSTS=["jetstream1.us-east.bsky.network", "jetstream2.us-east.bsky.network", "jetstream1.us-west.bsky.network"]
WANTED_COLLECTIONS=app.bsky.feed.post

# Metrics Configuration
STATSD_HOST=localhost
STATSD_PORT=8125

# Development Mode (uncomment for development)
# RUST_LOG=debug
# TURBO_BATCH_SIZE=1
